# ============================================
# x402 Product Reputation API - Configuration
# ============================================

# Server
PORT=4021
BASE_URL=http://localhost:4021

# Wallet - your receiving address for USDC payments
WALLET_ADDRESS=0xYourEvmAddressHere

# x402 Facilitator
# Testnet: https://x402.org/facilitator
# Mainnet: https://x402.org/facilitator (with CDP API keys)
FACILITATOR_URL=https://x402.org/facilitator

# Network
# Testnet: eip155:84532 (Base Sepolia)
# Mainnet: eip155:8453 (Base)
NETWORK=eip155:84532

# Pricing (USDC)
PRICE_ANALYZE=$0.05
PRICE_COMPARE=$0.08
PRICE_MONITOR=$0.03

# LLM - Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Reddit API (for higher rate limits)
# Without these, we use Reddit's public JSON API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: YouTube Data API v3 key
# Without this, we scrape transcript via youtube-transcript lib
YOUTUBE_API_KEY=
